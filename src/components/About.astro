---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="max-w-6xl mx-auto py-24 px-4">
	<div class="flex flex-col gap-14">
		<header class="space-y-4 max-w-3xl">
			<p class="text-xs uppercase tracking-[0.3em] text-white/40">{t('about.eyebrow')}</p>
			<h2 class="text-white text-4xl font-bold tracking-wide leading-tight">
				{t('about.title')}
			</h2>
			<p class="text-white/60 text-lg leading-relaxed">
				{t('about.lead')}
			</p>
		</header>

		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
			<div
				class="lg:col-span-2 bg-black/40 border border-white/10 rounded-3xl p-7 md:p-8 backdrop-blur-sm shadow-[0_20px_60px_rgba(0,0,0,0.5)] space-y-4"
			>
				<span class="text-xs uppercase tracking-[0.25em] text-orange-500/80">{t('about.historyLabel')}</span>
				<p class="text-white/75 leading-relaxed text-sm md:text-base">
					{t('about.historyP1Before')}
					<span class="text-white font-medium">{t('about.value1981')}</span>
					{t('about.historyP1After')}
				</p>
				<p class="text-white/75 leading-relaxed text-sm md:text-base">
					{t('about.historyP2')}
				</p>
			</div>

			<div
				class="bg-black/40 border border-white/10 rounded-3xl p-7 backdrop-blur-sm shadow-[0_20px_60px_rgba(0,0,0,0.5)] flex flex-col justify-between gap-6"
			>
				<span class="text-xs uppercase tracking-[0.25em] text-orange-500/80">{t('about.glanceLabel')}</span>
				<ul class="space-y-4">
					{[
						{ labelKey: 'about.founded', valueKey: 'about.value1981' },
						{ labelKey: 'about.headquarters', valueKey: 'about.valueHq' },
						{ labelKey: 'about.founders', valueKey: 'about.valueFounders' },
						{ labelKey: 'about.knownFor', valueKey: 'about.valueKnownFor' },
					].map(({ labelKey, valueKey }) => (
						<li class="flex flex-col gap-0.5 border-b border-white/10 pb-4 last:border-b-0 last:pb-0">
							<span class="text-white/40 uppercase tracking-[0.2em] text-xs">{t(labelKey)}</span>
							<span class="text-white text-sm font-medium">{t(valueKey)}</span>
						</li>
					))}
				</ul>
			</div>
		</div>

		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{[
				{
					stat: '40+',
					labelKey: 'about.statYearsLabel',
					descKey: 'about.statYearsDesc',
				},
				{
					stat: '↑',
					labelKey: 'about.statTrainLabel',
					descKey: 'about.statTrainDesc',
				},
				{
					stat: '♡',
					labelKey: 'about.statCommunityLabel',
					descKey: 'about.statCommunityDesc',
				},
				{
					stat: '✦',
					labelKey: 'about.statAwardsLabel',
					descKey: 'about.statAwardsDesc',
				},
			].map(({ stat, labelKey, descKey }) => (
				<div
					class="bg-black/30 border border-white/10 rounded-3xl p-6 backdrop-blur-sm shadow-[0_15px_50px_rgba(0,0,0,0.4)] flex flex-col gap-3"
				>
					<span class="text-orange-400 text-2xl font-bold">{stat}</span>
					<h3 class="text-white text-sm font-semibold tracking-wide uppercase">{t(labelKey)}</h3>
					<p class="text-white/50 text-xs leading-relaxed">{t(descKey)}</p>
				</div>
			))}
		</div>

		<div
			class="bg-gradient-to-r from-orange-950/30 via-black/40 to-black/40 border border-orange-900/30 rounded-3xl p-7 md:p-10 backdrop-blur-sm shadow-[0_20px_60px_rgba(0,0,0,0.5)] flex flex-col md:flex-row md:items-center gap-6"
		>
			<blockquote class="flex-1 space-y-3">
				<p class="text-white/80 text-base md:text-lg italic leading-relaxed">
					{t('about.quote')}
				</p>
				<footer class="text-white/40 text-xs uppercase tracking-[0.25em]">
					{t('about.quoteFooter')}
				</footer>
			</blockquote>
			<a
				href="https://www.kyotoanimation.co.jp/"
				target="_blank"
				rel="noreferrer"
				class="shrink-0 inline-flex items-center justify-center gap-2 text-sm text-white/60 hover:text-white border border-white/10 hover:border-white/30 px-5 py-3 rounded-2xl transition-all duration-300"
			>
				{t('about.officialSite')} <span>↗</span>
			</a>
		</div>
	</div>
</section>
