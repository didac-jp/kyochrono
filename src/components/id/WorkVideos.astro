---
import Video from '../Video.astro';

type VideoEntry = { id: string; title: string; type: 'youtube' | 'animethemes' };

interface Props {
    videoGroups: [string, VideoEntry[]][];
}

const { videoGroups } = Astro.props;
---

{videoGroups.length > 0 && (
    <div class={`grid gap-6 bg-black/50 border border-white/10 rounded-3xl p-5 md:p-6 backdrop-blur-md shadow-[0_20px_70px_rgba(0,0,0,0.7)] ${videoGroups.length > 1 ? 'lg:grid-cols-2' : ''}`}>
        {videoGroups.map(([groupTitle, groupVideos]) => (
            <div class="space-y-3">
                <div class="flex items-center gap-3">
                    <span class="text-white/50 text-sm font-semibold tracking-[0.2em] uppercase">
                        {groupTitle}
                    </span>
                    {groupVideos.length > 1 && (
                        <div class="flex gap-1.5">
                            {groupVideos.map((_, i) => (
                                <button
                                    data-selector
                                    data-group={groupTitle}
                                    data-idx={i}
                                    class={`w-6 h-6 text-xs rounded-md border transition-colors duration-150 cursor-pointer ${i === 0 ? 'border-white/40 text-white bg-white/10' : 'border-white/10 text-white/30 hover:text-white/60 hover:border-white/30'}`}
                                >
                                    {i + 1}
                                </button>
                            ))}
                        </div>
                    )}
                </div>
                <div class="relative aspect-[16/9]">
                    {groupVideos.map((video, i) => (
                        <div
                            data-video-slot
                            data-group={groupTitle}
                            data-idx={i}
                            class={`absolute inset-0${i > 0 ? ' invisible pointer-events-none' : ''}`}
                        >
                            <Video id={video.id} title={video.title} type={video.type} showTitle={false} />
                        </div>
                    ))}
                </div>
            </div>
        ))}
    </div>
)}

<script>
    import '../../scripts/id/work-videos.js';
</script>
