---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileTabBar from "../components/MobileTabBar.astro";
import "../styles/global.css";
import '@fontsource-variable/onest';
import { ClientRouter } from 'astro:transitions';
import favicon from '../assets/logo.svg?url';
import { SEO } from 'astro-seo';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
	title?: string;
	lang?: Lang;
	description?: string;
	ogImage?: string;
	ogImageAlt?: string;
}

const {
	title = 'A KyoAni Chronicle',
	lang: langProp,
	description: descriptionProp,
	ogImage,
	ogImageAlt,
} = Astro.props;
const urlLang = getLangFromUrl(Astro.url);
const lang = langProp ?? urlLang;
const t = useTranslations(lang);
const metaDescription = descriptionProp ?? t('meta.siteDescription');

const hasSite = Boolean(Astro.site);
const canonicalForSeo = hasSite ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const defaultOgImage = hasSite ? new URL('/favicon.svg', Astro.site).href : undefined;
const resolvedOgImage = ogImage ?? defaultOgImage;
const imageAlt = ogImageAlt ?? t('meta.logoAlt');
const useLargeTwitterCard = Boolean(ogImage);

const openGraph = hasSite && resolvedOgImage
	? {
			basic: {
				title,
				type: 'website' as const,
				image: resolvedOgImage,
				url: canonicalForSeo,
			},
			optional: {
				description: metaDescription,
				siteName: t('meta.siteTitle'),
				locale: lang === 'es' ? 'es_ES' : 'en_US',
			},
			image: {
				alt: imageAlt,
			},
		}
	: undefined;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href={favicon} />
		<meta name="generator" content={Astro.generator} />
		<SEO
			title={title}
			description={metaDescription}
			canonical={canonicalForSeo}
			openGraph={openGraph}
			twitter={{
				card: useLargeTwitterCard ? 'summary_large_image' : 'summary',
				title,
				description: metaDescription,
				...(resolvedOgImage && {
					image: resolvedOgImage,
					imageAlt,
				}),
			}}
		/>
		<ClientRouter />
	</head>
	<body>
		<div
			class="fixed inset-0 -z-10 bg-neutral-900"
			style="background:
				radial-gradient(ellipse 60% 55% at 75% -5%, rgba(217,70,239,0.17) 0%, transparent 100%),
				radial-gradient(ellipse 50% 50% at -5% 38%, rgba(124,58,237,0.14) 0%, transparent 100%),
				radial-gradient(ellipse 55% 50% at 58% 105%, rgba(162,28,175,0.12) 0%, transparent 100%),
				#171717"
		></div>
		<Header lang={lang} />
		<slot />
		<Footer lang={lang} />
		<MobileTabBar lang={lang} pathname={Astro.url.pathname} />
	</body>
</html>

<style>
	:root {
		color-scheme: light dark;
	}
	html {
		font-family: 'Onest', system-ui, sans-serif;
		scroll-behavior: smooth;
	}
	body {
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding: 0 24px;
	}

	@media (max-width: 768px) {
		body {
			padding-bottom: 72px;
		}
	}

</style>
