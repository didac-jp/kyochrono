---
import Pill from '../Pill.astro';
import PlayCircleIcon from '../../icons/play-circle.svg?raw';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getLangFromUrl, interpolate, useTranslations } from '../../i18n/utils';

interface Bso {
	ytmusic?: string[];
}

interface Props {
	description: string;
	date: string;
	title: string;
	hashtag?: string;
	hashtag_lnk?: string;
	bso?: Bso;
	anilist?: string | null;
	imgLink?: ImageMetadata;
	link?: string;
}

const { description, date, title, hashtag, hashtag_lnk, bso, anilist, imgLink, link } = Astro.props;

const t = useTranslations(getLangFromUrl(Astro.url));
const imgAlt = interpolate(t('work.imgAlt'), { title });
---

<aside class="space-y-5 bg-black/50 border border-white/10 rounded-3xl p-5 md:p-6 backdrop-blur-md shadow-[0_20px_70px_rgba(0,0,0,0.7)] self-start">
	<div class="space-y-3">
		<h2 class="text-sm font-semibold tracking-[0.25em] uppercase text-white/60">
			{t('work.description')}
		</h2>
		<div data-desc-wrap>
			<p data-desc-text class="text-sm md:text-base text-white/80 leading-relaxed line-clamp-5 md:line-clamp-6">
				{description}
			</p>
			<button
				type="button"
				data-desc-toggle
				data-read-more={t('work.readMore')}
				data-read-less={t('work.readLess')}
				class="hidden mt-2 text-xs uppercase tracking-[0.2em] text-white/40 hover:text-white/70 transition-colors cursor-pointer"
			>
				{t('work.readMore')}
			</button>
		</div>
	</div>

	<div class="grid gap-4 text-sm text-white/80">
		<div class="flex items-center justify-between gap-6 border-b border-white/10 pb-4">
			<span class="text-white/50 uppercase tracking-[0.2em] text-xs">
				{t('work.release')}
			</span>
			<span class="font-mono text-xs md:text-sm text-white">
				{date}
			</span>
		</div>

		{hashtag && (
			<div class="flex items-center justify-between gap-6 border-b border-white/10 pb-4">
				<span class="text-white/50 uppercase tracking-[0.2em] text-xs">
					{t('work.hashtags')}
				</span>
				<span class="font-mono text-xs md:text-sm text-white">
					<a href={hashtag_lnk} target="_blank" rel="noreferrer" class="text-white hover:text-indigo-300/80 transition-colors">
						{hashtag}
					</a>
				</span>
			</div>
		)}

		{bso?.ytmusic?.length && (
			<div class="flex items-center justify-between gap-6 border-b border-white/10 pb-4 min-w-0">
				<span class="text-white/50 uppercase tracking-[0.2em] text-xs shrink-0">
					{t('work.soundtrack')}
				</span>
				<div
					data-hscroll
					class="flex gap-1.5 overflow-x-auto min-w-0 max-w-full py-1 -my-1 px-1 -mx-1 cursor-grab active:cursor-grabbing"
					style="scrollbar-width: none;"
				>
					{bso.ytmusic.map((url, i) => (
						<span class="shrink-0">
							<Pill href={url} color="#FF0000">
								<Fragment set:html={PlayCircleIcon} />
								{t('work.ytMusic')}
								{bso.ytmusic!.length > 1 && <span class="opacity-60 font-mono text-xs">{i + 1}</span>}
							</Pill>
						</span>
					))}
				</div>
			</div>
		)}

		{anilist && (
			<div class="flex items-center justify-between border-b border-white/10 pb-4">
				<span class="text-white/50 uppercase tracking-[0.2em] text-xs shrink-0">
					{t('work.animePlatform')}
				</span>
				<Pill href={anilist} color="#6366f1">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5 shrink-0" aria-hidden="true">
						<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z" />
					</svg>
					<span class="text-[11px] font-medium tracking-wide">{t('work.anilist')}</span>
				</Pill>
			</div>
		)}
	</div>

	{imgLink && (
		<a
			href={link}
			target="_blank"
			rel="noreferrer"
			class="rounded-2xl border border-white/10 bg-black/60 block group mx-auto w-fit overflow-hidden"
		>
			<Image
				src={imgLink}
				alt={imgAlt}
				decoding="async"
				class="block max-h-24 md:max-h-28 transform transition-transform duration-500 group-hover:scale-105"
				loading="lazy"
			/>
		</a>
	)}
</aside>

<script>
	import '../../scripts/id/work-info.js';
</script>
