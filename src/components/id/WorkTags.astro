---
import type { Lang } from '../../i18n/ui';
import { interpolate, useTranslations } from '../../i18n/utils';
import { catalogTag, tagToSlug } from '../../utils/routes';

interface Props {
	tags: string[];
	lang: Lang;
}

const { tags, lang } = Astro.props;
const t = useTranslations(lang);

const list = tags ?? [];
const show = list.length > 0;
---

{
	show && (
		<aside class="bg-black/50 border border-white/10 rounded-3xl p-4 md:p-5 backdrop-blur-md shadow-[0_20px_70px_rgba(0,0,0,0.7)] space-y-3">
			<div class="flex flex-wrap justify-center items-center gap-2">
				{list.map((tag) => (
					<a
						href={catalogTag(lang, tagToSlug(tag))}
						class="text-white/50 uppercase tracking-[0.2em] text-xs border border-white/10 px-2 py-1 rounded-md hover:border-white/40 hover:text-white/80 hover:bg-white/10 transition-colors"
						aria-label={interpolate(t('catalog.tagAriaLabel'), { tag })}
					>
						{tag}
					</a>
				))}
			</div>
		</aside>
	)
}
