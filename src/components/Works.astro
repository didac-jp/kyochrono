---
import { type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { seriesHue } from '../utils/series';
import UpButton from './UpButton.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { workDetailPath } from '../utils/routes';
import ChevronLeftIcon from '../icons/chevron-left.svg?raw';

interface Props {
	works: CollectionEntry<'works'>[];
}

const { works } = Astro.props;

type WorkEntry = CollectionEntry<'works'>;

const EAGER_COUNT = 6;
const HIGH_PRIORITY_COUNT = 3;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="works" class="max-w-6xl mx-auto pb-14 px-4">
	<div id="works-grid" class="mt-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-3 items-stretch">
		{works.map(({ id, data: { title, img, date, series } }: WorkEntry, i: number) => {
			const year = date.match(/\d{4}/)?.[0] ?? '0';
			const hue = series ? seriesHue(series) : null;
			const bgStyle =
				hue !== null ? `background-color: hsla(${hue}, 55%, 45%, 0.13);` : '';
			const footerGradient =
				hue !== null
					? `background: linear-gradient(to bottom, hsla(${hue},55%,25%,0.55), hsla(${hue},50%,12%,0.75), hsla(${hue},45%,4%,0.96));`
					: '';
			const detailHref = workDetailPath(lang, id);
			return (
				<article
					class="overflow-hidden group relative flex flex-col border border-white/10 rounded-2xl shadow-[0_20px_60px_rgba(0,0,0,0.6)] backdrop-blur-sm h-full bg-black/30 transition-[transform,box-shadow,border-color] duration-300 ease-out hover:border-white/40 hover:shadow-[0_28px_72px_-8px_rgba(0,0,0,0.85)] works-card-hover"
					style={bgStyle}
					data-reveal
					data-index={i}
					data-title={title}
					data-year={year}
					data-series={series ?? ''}
				>
					<div class="relative">
						<a href={detailHref}>
							<Image
								transition:name={`img-${id}`}
								src={img}
								alt={title}
								widths={[300, 400, 600]}
								sizes="(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 30vw"
								decoding="async"
								class="w-full aspect-[3/4] object-cover"
								loading={i < EAGER_COUNT ? 'eager' : 'lazy'}
								fetchpriority={i < HIGH_PRIORITY_COUNT ? 'high' : 'auto'}
							/>
						</a>
						<div class="pointer-events-none absolute inset-0 border border-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
					</div>

					<div
						class={`flex flex-col gap-3 p-6 flex-1 ${hue === null ? 'bg-gradient-to-b from-black/60 via-black/70 to-black' : ''}`}
						style={footerGradient}
					>
						<h3 class="text-white text-xl font-semibold tracking-wide uppercase">{title}</h3>

						<div class="mt-auto flex items-center justify-end text-xs text-white/50 border-t border-white/10 pt-3 gap-2 min-w-0">
							<a
								href={detailHref}
								class="group/btn inline-flex items-center gap-1.5 rounded-md border border-white/15 bg-white/[0.06] px-3.5 py-1.5 text-[0.8125rem] font-medium text-white/85 transition-[color,background-color,border-color] duration-200 hover:border-white/28 hover:bg-white/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/35"
							>
								{t('works.viewWork')}
								<span
									class="inline-flex size-3.5 shrink-0 rotate-180 text-white/60 transition-colors group-hover/btn:text-white [&>svg]:size-full"
									set:html={ChevronLeftIcon}
								/>
							</a>
						</div>
					</div>
				</article>
			);
		})}
	</div>
</section>

<UpButton />

<style>
	article[data-reveal] {
		content-visibility: auto;
		contain-intrinsic-size: auto 450px;
	}
	article[data-reveal].below-fold {
		opacity: 0;
		transform: translateY(24px);
		transition: opacity 0.4s ease, transform 0.4s ease;
	}
	article[data-reveal].revealed {
		opacity: 1;
		transform: translateY(0);
		transition: opacity 0.6s ease, transform 0.6s ease;
	}

	article[data-reveal].works-card-hover:not(.below-fold):hover {
		transform: translateY(-0.375rem);
	}
	article[data-reveal].works-card-hover.below-fold:hover {
		transform: translateY(calc(1.5rem - 0.375rem));
	}
</style>

<script>
	import '../scripts/works.js';
</script>
