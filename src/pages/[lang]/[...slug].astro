---
import Layout from '../../layouts/Layout.astro';
import UpButton from '../../components/UpButton.astro';
import BackButton from '../../components/BackButton.astro';
import WorkLinkCard from '../../components/WorkLinkCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import CatalogTagChips from '../../components/catalog/CatalogTagChips.astro';
import { getCollection } from 'astro:content';
import { getWorksByDecade, getDecadeKey } from '../../utils/decades';
import { getWorksBySeries, seriesHue } from '../../utils/series';
import { getTagCatalogEntries, catalogTagCatchallSlug, CATALOG_TAG_SLUG_PREFIX } from '../../utils/tags';
import { dateSortKey } from '../../utils/date';
import { supportedLangs, useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { homePath, catalogAnimesQuery, tagToSlug } from '../../utils/routes';

export async function getStaticPaths() {
	const decadesMap = await getWorksByDecade();
	const tagEntries = await getTagCatalogEntries();
	const out: Array<{ params: { lang: Lang; slug: string } }> = [];
	for (const lang of supportedLangs) {
		out.push({ params: { lang, slug: 'catalog/animes' } });
		for (const decade of decadesMap.keys()) {
			out.push({ params: { lang, slug: `catalog/decade/${decade}` } });
		}
		for (const { tagSlug } of tagEntries) {
			out.push({ params: { lang, slug: catalogTagCatchallSlug(tagSlug) } });
		}
	}
	return out;
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const rawSlug = Astro.params.slug;

if (typeof rawSlug === 'string' && rawSlug.startsWith('catalog/decade/')) {
	const decade = rawSlug.slice('catalog/decade/'.length);
	return Astro.redirect(catalogAnimesQuery(lang, { decade }), 301);
}

if (typeof rawSlug === 'string' && rawSlug.startsWith(CATALOG_TAG_SLUG_PREFIX)) {
	const tag = rawSlug.slice(CATALOG_TAG_SLUG_PREFIX.length);
	return Astro.redirect(catalogAnimesQuery(lang, { tag }), 301);
}

if (rawSlug !== 'catalog/animes') {
	return Astro.redirect('/404');
}

const pageTitle = `${t('catalog.animesTitle')}${t('meta.titleSuffix')}`;

const bySeries = await getWorksBySeries();
const seriesKeys = [...bySeries.keys()].sort((a, b) => {
	if (a === '_standalone') return 1;
	if (b === '_standalone') return -1;
	return a.localeCompare(b);
});
const sections = seriesKeys
	.map((key) => {
		const w = (bySeries.get(key) ?? [])
			.slice()
			.sort((a, b) => dateSortKey(a.data.date) - dateSortKey(b.data.date));
		return {
			key,
			label: key === '_standalone' ? t('catalog.standalone') : key,
			works: w,
		};
	})
	.filter((s) => s.works.length > 0);

const allWorks = (await getCollection('works'))
	.slice()
	.sort((a, b) => dateSortKey(a.data.date) - dateSortKey(b.data.date));

const uniqueTagSet = new Set<string>();
for (const work of allWorks) {
	for (const tag of work.data.tags) uniqueTagSet.add(tag);
}
const catalogCatFilterEntries = [...uniqueTagSet]
	.sort((a, b) => a.localeCompare(b))
	.map((tagLabel) => ({ tagSlug: tagToSlug(tagLabel), tagLabel }));
---

<Layout title={pageTitle} lang={lang}>
	<main>
		<div class="max-w-6xl mx-auto pt-10 px-4">
			<BackButton href={homePath(lang)} label={t('back.home')} />

			<header class="mt-6 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between sm:gap-8">
				<div class="space-y-1 min-w-0">
					<p class="text-xs uppercase tracking-[0.3em] text-white/40">{t('catalog.seriesEyebrow')}</p>
					<h1 class="text-white text-5xl font-bold tracking-tight">{t('catalog.animesTitle')}</h1>
				</div>
				<SearchBar variant="header" placeholder={t('search.placeholder')} autoAttachCatalogFilter={false} />
			</header>
			<CatalogTagChips
				tags={catalogCatFilterEntries}
				label={t('catalog.tagsRow')}
				allLabel={t('catalog.filterAll')}
			/>
		</div>

		<div
			class="max-w-6xl mx-auto px-4 mt-10 pb-14 hidden"
			data-catalog-filtered-root
			aria-hidden="true"
		>
			<h2 class="text-xl font-semibold tracking-wide text-white mb-6 pb-2 border-b border-white/10">
				{t('catalog.animesTitle')}
			</h2>
			<ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
				{
					allWorks.map(({ id, data: { title, img, date, series, tags } }) => {
						const decade = getDecadeKey(date);
						const tagSlugs = (tags ?? [])
							.map((tag) => tagToSlug(tag))
							.filter(Boolean)
							.join(' ');
						const cardHue = series ? seriesHue(series) : null;
						return (
							<li
								data-catalog-item
								data-title={title}
								data-series={series ?? ''}
								data-decade={decade}
								data-tags={tagSlugs}
								data-cats={(tags ?? []).join(',')}
							>
								<WorkLinkCard
									id={id}
									title={title}
									img={img}
									date={date}
									hue={cardHue}
									variant="catalog"
								/>
							</li>
						);
					})
				}
			</ul>
		</div>

		<div
			class="max-w-6xl mx-auto px-4 mt-12 pb-14 space-y-16 scroll-mt-16"
			data-catalog-franchise-root
			data-catalog-active-root
		>
			{
				sections.map(({ key, label, works }) => {
					const hue = key !== '_standalone' ? seriesHue(key) : null;
					return (
						<section
							class="scroll-mt-16"
							aria-labelledby={`series-${key}`}
							data-series-section
							data-series-key={key}
						>
							<h2
								id={`series-${key}`}
								class="text-xl font-semibold tracking-wide text-white mb-6 pb-2 border-b border-white/10"
								style={hue !== null ? `color: hsl(${hue}, 60%, 78%); border-color: hsla(${hue}, 50%, 50%, 0.25);` : undefined}
							>
								{label}
							</h2>
							<ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
								{works.map(({ id, data: { title, img, date, series, tags } }) => {
									const decade = getDecadeKey(date);
									const tagSlugs = (tags ?? [])
										.map((tag) => tagToSlug(tag))
										.filter(Boolean)
										.join(' ');
									const cardHue = series ? seriesHue(series) : null;
									return (
										<li
											data-catalog-item
											data-title={title}
											data-series={series ?? ''}
											data-decade={decade}
											data-tags={tagSlugs}
											data-cats={(tags ?? []).join(',')}
										>
											<WorkLinkCard
												id={id}
												title={title}
												img={img}
												date={date}
												hue={cardHue}
												variant="catalog"
											/>
										</li>
									);
								})}
							</ul>
						</section>
					);
				})
			}
		</div>

		<UpButton />
	</main>
</Layout>

<script>
	import '../../scripts/catalog/catalog-filters.js';
</script>
