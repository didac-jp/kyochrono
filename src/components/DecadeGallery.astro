---
import { getWorksByDecade } from '../utils/decades';
import { Image } from 'astro:assets';
import { catalogAnimesDecade } from '../utils/routes';
import { getLangFromUrl, interpolate, useTranslations } from '../i18n/utils';
import ChevronLeftIcon from '../icons/chevron-left.svg?raw';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const decadesMap = await getWorksByDecade();
const preferredCoversByDecade: Record<string, string> = {
	'2000s': 'haruhi_2009',
	'2010s': 'tamako_movie',
	'2020s': 'city',
};

function decadeYearRange(key: string): string {
	const m = key.match(/^(\d{4})s$/);
	if (m) {
		const start = parseInt(m[1], 10);
		return `${start}–${start + 9}`;
	}
	return key === 'unknown' ? t('catalog.undated') : key;
}

function decadeCardFromWorks(key: string, works: NonNullable<ReturnType<typeof decadesMap.get>>) {
	const preferredSlug = preferredCoversByDecade[key];
	const coverWork = works.find((work) => work.id === preferredSlug) ?? works[0];
	return {
		key,
		label: key,
		count: works.length,
		cover: coverWork.data.img,
		coverTitle: coverWork.data.title,
		yearRange: decadeYearRange(key),
	};
}

const showcaseOrder = ['2000s', '2010s', '2020s'] as const;
const decadesShowcase: ReturnType<typeof decadeCardFromWorks>[] = [];
const usedKeys = new Set<string>();
for (const key of showcaseOrder) {
	const works = decadesMap.get(key);
	if (!works?.length) continue;
	decadesShowcase.push(decadeCardFromWorks(key, works));
	usedKeys.add(key);
	if (decadesShowcase.length >= 3) break;
}
if (decadesShowcase.length < 3) {
	const rest = [...decadesMap.entries()]
		.sort(([a], [b]) => a.localeCompare(b))
		.filter(([k]) => !usedKeys.has(k));
	for (const [key, works] of rest) {
		if (decadesShowcase.length >= 3) break;
		decadesShowcase.push(decadeCardFromWorks(key, works));
		usedKeys.add(key);
	}
}
---

<section class="max-w-6xl mx-auto py-16 sm:py-20 lg:py-24">
	<div class="grid gap-10 lg:gap-12 lg:items-center px-2 sm:px-4 lg:grid-cols-[minmax(0,0.618fr)_minmax(0,0.382fr)]">
		<div>
			<div class="inline-flex items-center gap-3">
				<span class="text-white/55 text-xs uppercase tracking-[0.34em]">
					{t('landing.badge')}
				</span>
			</div>

			<h1 class="mt-6 text-white text-6xl sm:text-7xl lg:text-8xl font-semibold tracking-tight leading-[0.95]">
				<span class="block">{t('landing.titleLine1')}</span>
				<span class="block">{t('landing.titleLine2')}</span>
				<span class="block text-orange-500/85">{t('landing.titleLine3')}</span>
			</h1>

			<p class="mt-5 text-white/70 text-base sm:text-lg max-w-prose">
				{t('landing.intro')}
			</p>

			<nav class="mt-7 flex flex-wrap gap-2">
				<a
					href="#about"
					class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.03] px-3.5 py-2 text-sm text-white/75 hover:text-white hover:border-white/20 hover:bg-white/[0.05] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-fuchsia-300/70 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900"
				>
					{t('landing.aboutCta')}
				</a>
			</nav>
		</div>

		<div>
			<div class="grid gap-3 sm:gap-4 max-w-[520px] lg:ml-auto">
				{decadesShowcase.map(({ key, label, count, cover, coverTitle, yearRange }, i) => (
					<a
						href={catalogAnimesDecade(lang, key)}
						aria-label={interpolate(t('landing.decadeAria'), { decade: label, range: yearRange })}
						class:list={[
							'group relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.02]',
							'shadow-[0_14px_60px_rgba(0,0,0,0.45)]',
							'transform-gpu will-change-transform transition duration-500 motion-reduce:transition-none',
							'hover:-translate-y-0.5 hover:scale-[1.02] hover:border-white/20 hover:z-10',
							'focus:outline-none focus-visible:ring-2 focus-visible:ring-fuchsia-300/70 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900 focus-visible:z-10',
						]}
					>
						<div
							class:list={[
								'relative flex items-center transition-[max-height] duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] motion-reduce:transition-none',
								'delay-75 group-hover:delay-0',
								'max-h-[168px] sm:max-h-[182px] group-hover:max-h-[520px] sm:group-hover:max-h-[560px]',
								i === 0
									? 'lg:max-h-[176px] lg:group-hover:max-h-[560px]'
									: 'lg:max-h-[164px] lg:group-hover:max-h-[520px]',
							]}
						>
							<Image
								src={cover}
								alt={coverTitle}
								widths={i === 0 ? [640, 900, 1200] : [520, 780, 1040]}
								sizes="(max-width: 1024px) 100vw, 520px"
								decoding="async"
								class="block w-full h-auto transition-[filter] duration-700 motion-reduce:transition-none group-hover:saturate-[1.12] group-hover:contrast-[1.06] origin-center"
								loading={i <= 1 ? 'eager' : 'lazy'}
								fetchpriority={i <= 1 ? 'high' : 'auto'}
							/>

							<div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/25 to-transparent" />
							<div class="absolute inset-0 bg-[radial-gradient(ellipse_75%_70%_at_0%_50%,rgba(217,70,239,0.28),transparent_60%),radial-gradient(ellipse_70%_60%_at_20%_120%,rgba(124,58,237,0.18),transparent_62%)] opacity-80" />
							<div class="absolute inset-0 ring-1 ring-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-3xl pointer-events-none" />

							<div class="absolute inset-0 p-4 sm:p-5 flex flex-col justify-end">
								<div
									class="rounded-2xl border border-white/10 bg-black/35 backdrop-blur-md shadow-[0_12px_40px_rgba(0,0,0,0.35)] px-4 py-3 sm:px-5 sm:py-4"
								>
									<div class="flex items-end justify-between gap-5">
										<div class="min-w-0">
											<p class="text-white/60 text-xs uppercase tracking-[0.30em]">
												{yearRange}
											</p>
											<h3
												class:list={[
													'mt-2 text-white font-semibold tracking-tight leading-none text-3xl sm:text-4xl',
												]}
											>
												{label}
											</h3>
										</div>

										<div class="shrink-0 text-right">
											<p class="text-white/60 text-xs tabular-nums">
												{count}
												{' '}
												{count === 1 ? t('landing.workOne') : t('landing.workMany')}
											</p>
											<p class="mt-2 inline-flex items-center gap-2 text-white/80 group-hover:text-white transition-colors text-sm sm:text-base">
												{t('landing.enter')}
												<span style="rotate: 180deg;">
													<Fragment set:html={ChevronLeftIcon} />
												</span>
											</p>
										</div>
									</div>
								</div>
							</div>
						</div>
					</a>
				))}
			</div>
		</div>
	</div>
</section>
