---
import ChevronLeftIcon from '../icons/chevron-left.svg?raw';

interface Props {
    href?: string;
    label?: string;
    smartBack?: boolean;
}

const { href, label, smartBack = false } = Astro.props;
const resolvedHref = href ?? '/';
const resolvedLabel = smartBack ? 'Back' : (label ?? 'Back');
---

<a
    href={resolvedHref}
    {...(smartBack ? { 'data-smart-back': 'true' } : {})}
    class="inline-flex items-center gap-2 text-xs tracking-[0.3em] text-white/40 hover:text-white transition-colors group"
>
    <span class="text-base leading-none group-hover:-translate-x-0.5 transition-transform duration-200">
        <Fragment set:html={ChevronLeftIcon} />
    </span>
    <span>{resolvedLabel}</span>
</a>

<script>
    import '../scripts/back-button.js';
</script>
