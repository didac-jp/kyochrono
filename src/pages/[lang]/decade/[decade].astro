---
import { getWorksByDecade } from '../../../utils/decades';
import { catalogDecade } from '../../../utils/routes';
import { supportedLangs } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
	const map = await getWorksByDecade();
	return [...map.keys()].flatMap((decade) =>
		supportedLangs.map((lang) => ({
			params: { lang, decade },
		})),
	);
}

const lang = Astro.params.lang as Lang;
const { decade } = Astro.params;
return Astro.redirect(catalogDecade(lang, decade!), 301);
---
