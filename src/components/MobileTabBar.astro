---
import { navLinksForLang } from '../utils/routes';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
	lang: Lang;
	pathname: string;
}

const { pathname, lang } = Astro.props;
const t = useTranslations(lang);

const normalizedPath = pathname.endsWith('/') ? pathname : `${pathname}/`;

function isActive(href: string) {
	const h = href.endsWith('/') ? href : `${href}/`;
	return normalizedPath === h;
}

const navLinks = navLinksForLang(lang, t);
---

<nav
	aria-label={t('mobileNav.aria')}
	class="md:hidden fixed inset-x-0 bottom-0 z-50 border-t border-white/10 bg-neutral-950/70 backdrop-blur-md"
>
	<div class="mx-auto max-w-5xl px-4">
		<ul
			class="grid"
			style={`grid-template-columns: repeat(${navLinks.length}, minmax(0, 1fr));`}
		>
			{navLinks.map(({ href, label }) => {
				const active = isActive(href);
				return (
					<li>
						<a
							href={href}
							data-astro-prefetch
							aria-current={active ? 'page' : undefined}
							class={`flex flex-col items-center justify-center gap-1 py-3 text-[11px] tracking-wide transition-colors ${
								active ? 'text-white' : 'text-white/55 hover:text-white/85'
							}`}
						>
							<span class={`h-1 w-6 rounded-full ${active ? 'bg-white/80' : 'bg-transparent'}`} />
							<span class="leading-none">{label}</span>
						</a>
					</li>
				);
			})}
		</ul>
	</div>
</nav>
