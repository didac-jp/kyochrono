---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
    img: ImageMetadata;
    title: string;
    slug: string;
}

const { img, title, slug } = Astro.props;
---

<figure class="group relative overflow-hidden rounded-3xl border border-white/10 bg-black/60 shadow-[0_25px_80px_rgba(0,0,0,0.8)] flex items-center justify-center md:aspect-[1/1]">
    <Image
        transition:name={`img-${slug}`}
        src={img}
        alt={title}
        widths={[400, 600, 800]}
        sizes="(max-width: 768px) 90vw, 50vw"
        decoding="async"
        fetchpriority="high"
        class="w-full h-full object-contain"
    />
</figure>
